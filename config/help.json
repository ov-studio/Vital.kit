{
    "shared": {
        "help":  { "syntax": "", "desc": "Shows this list of available commands" },
        "version": { "syntax": "", "desc": "Displays the current build version" },
        "clear": { "syntax": "", "desc": "Clears the console output" }
    },
    
    "server": {
        "srun": { "syntax": "<code>", "desc": "Executes a Lua statement and returns the result" },
        "kick": { "syntax": "<id>", "desc": "Kicks a player by peer ID" },
        "players": { "syntax": "", "desc": "Lists all connected players" },
        "refresh":  { "syntax": "", "desc": "Rescans and reloads all resources" },
        "start": { "syntax": "<resource_name>", "desc": "Starts the specified loaded resource" },
        "stop": { "syntax": "<resource_name>", "desc": "Stops the specified running resource" },
        "restart": { "syntax": "<resource_name>", "desc": "Restarts the specified running resource" },
        "stop": { "syntax": "", "desc": "Gracefully shuts down the server" }
    },
    
    "client": {
        "crun": { "syntax": "<code>", "desc": "Compiles and runs a Lua chunk with full scope" },
        "connect": { "syntax": "<ip> <port>", "desc": "Connects to a server" },
        "disconnect": { "syntax": "", "desc": "Disconnects from the current server" },
        "status": { "syntax": "", "desc": "Shows current connection status" }
    }
}